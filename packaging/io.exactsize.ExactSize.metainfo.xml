<component type="desktop-application">
  <id>io.exactsize.ExactSize</id>
  <name>ExactSize</name>
  <summary>Compress videos to a strict maximum file size</summary>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT</project_license>
  <description>
    <p>
      ExactSize calculates a bitrate budget from the video duration, selected audio settings,
      and container overhead. It verifies the completed file and automatically corrects any
      overshoot before publishing the output.
    </p>
  </description>
  <categories>
    <category>AudioVideo</category>
    <category>Video</category>
  </categories>
